rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Avatars: each user can write to their own folder; anyone signed in can read.
    match /avatars/{userId}/{file=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Post images: any signed-in user can upload to their own folder, anyone signed in can read.
    match /posts/{userId}/{file=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Gallery photos
    match /gallery/{userId}/{file=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
